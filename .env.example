# MongoDB Atlas Configuration
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# IMPORTANT: If your password has special characters, URL-encode them:
#   # → %23, @ → %40, : → %3A, etc.
# Example: Tushar123# → Tushar123%23
MONGODB_URI=mongodb+srv://Tushar:Tushar123%23@cluster0.xxdrret.mongodb.net/ddcet_hub

# JWT Secret Key (change this to a strong random string in production!)
SECRET_KEY=your-production-secret-key-change-this-12345

# Server Port
PORT=5001

# Environment (development or production)
NODE_ENV=development

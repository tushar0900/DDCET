{
  "version": 2,
  "buildCommand": "cd backend && npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/server.js"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/backend/server.js"
    }
  ]
}
